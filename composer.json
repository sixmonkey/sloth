{
    "name": "sixmonkey/sloth",
    "description": "A WordPress theme framework built with Laravel components",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "brain/hierarchy": "^2.0 || ^3.0",
        "cakephp/utility": "^3.0 || ^4.0",
        "corcel/acf": "^3.0 || ^4.0",
        "gossi/docblock": "^1.6",
        "illuminate/container": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "illuminate/filesystem": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "illuminate/http": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "illuminate/pagination": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "illuminate/validation": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "illuminate/view": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "jgrossi/corcel": "^5.0 || ^6.0 || ^7.0 || ^8.0 || ^9.0",
        "jjgrainger/posttypes": "^3.0",
        "league/climate": "^3.0 || ^3.8",
        "milo/vendor-versions": "^1.1 || ^2.0",
        "nikic/fast-route": "^1.3",
        "nofutur3/tracy-gitpanel": "^0.9",
        "org_heigl/hyphenator": "^2.0 || ^2.4 || ^3.0",
        "spatie/emoji": "^4.0",
        "spatie/image": "^1.10 || ^2.0 || ^3.0",
        "tracy/tracy": "^2.10",
        "twig/twig": "^3.0",
        "vlucas/phpdotenv": "^2.6 || ^3.0 || ^5.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.50"
    },
    "autoload": {
        "psr-4": {
            "Sloth\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "docs": "phpdocumentor"
    }
}
