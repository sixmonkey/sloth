<h1>🦥 Sloth</h1>
<div class="tracy-inner">

    {# Template Hierarchy #}
    <h2>Template Hierarchy</h2>
    <table>
        <tr>
            <th>Current Layout</th>
            <td><strong>{{ currentTemplate }}</strong></td>
        </tr>
        {% for template in templates %}
        <tr>
            <th>{% if loop.first %}Candidates{% endif %}</th>
            <td {% if template == currentTemplate %}style="font-weight:bold"{% endif %}>
                {{ template }}
            </td>
        </tr>
        {% endfor %}
    </table>

    {# Performance #}
    <h2>Performance</h2>
    <table>
        <tr><th>Memory</th><td>{{ performance.memory }}</td></tr>
        <tr><th>Peak Memory</th><td>{{ performance.peak_memory }}</td></tr>
        <tr><th>Time</th><td>{{ performance.time }}</td></tr>
    </table>

    {# Container #}
    <h2>Container</h2>
    <table>
        <tr><th>Environment</th><td>{{ container.environment }}</td></tr>
        <tr><th>Providers</th><td>{{ container.providers }}</td></tr>
        <tr><th>Bindings</th><td>{{ container.bindings }}</td></tr>
    </table>

    {# WordPress #}
    <h2>WordPress</h2>
    <table>
        <tr><th>Post Type</th><td>{{ wordpress.post_type }}</td></tr>
        <tr><th>Queried Object ID</th><td>{{ wordpress.queried_object_id }}</td></tr>
        <tr><th>Template Slug</th><td>{{ wordpress.template_slug }}</td></tr>
        <tr><th>Registered Hooks</th><td>{{ wordpress.hooks }}</td></tr>
        <tr><th>Is Admin</th><td>{{ wordpress.is_admin }}</td></tr>
    </table>

    {# Sloth Models & Taxonomies #}
    <h2>Sloth</h2>
    <table>
        <tr>
            <th>Models</th>
            <td>
                {% if sloth.models is not empty %}
                    {{ sloth.models|join(', ') }}
                {% else %}
                    <em>none</em>
                {% endif %}
            </td>
        </tr>
        <tr>
            <th>Taxonomies</th>
            <td>
                {% if sloth.taxonomies is not empty %}
                    {{ sloth.taxonomies|join(', ') }}
                {% else %}
                    <em>none</em>
                {% endif %}
            </td>
        </tr>
    </table>

    {# ACF #}
    {% if acf is not empty %}
        <h2>ACF Field Groups</h2>
        <table>
            {% for group in acf %}
                <tr><td>{{ group }}</td></tr>
            {% endfor %}
        </table>
    {% endif %}

</div>
